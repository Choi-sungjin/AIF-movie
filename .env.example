# .env.example
# 이 파일을 복사해서 .env.local 로 이름 변경 후 값을 채워주세요.
# TMDB API 키 발급: https://www.themoviedb.org/settings/api
# .env.local 은 절대 Git에 커밋하지 마세요!

NEXT_PUBLIC_TMDB_API_KEY=your_tmdb_api_key_here
NEXT_PUBLIC_TMDB_BASE_URL=https://api.themoviedb.org/3
NEXT_PUBLIC_TMDB_IMAGE_BASE=https://image.tmdb.org/t/p/w500
NEXT_PUBLIC_TMDB_BACKDROP=https://image.tmdb.org/t/p/original
